// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "semantic_tokens": "combined",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "indent_guides": {
    "background_coloring": "disabled"
  },
  "inlay_hints": {
    "show_background": false
  },
  "edit_predictions": {
    "provider": "mercury"
  },
  "colorize_brackets": true,
  "gutter": {
    "line_numbers": true
  },
  "helix_mode": true,
  "agent": {
    "dock": "right",
    "play_sound_when_agent_done": "always",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-6-1m-context-thinking-latest"
    },
    "model_parameters": []
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "preferred_line_length"
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "telemetry": {
    "metrics": false
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "lsp": {
      "yaml-language-server": {
        "yaml.schemas": {
          "https://raw.githubusercontent.com/yannh/kubernetes-json-schema/master/v1.27.9-standalone-strict/all.json": "/*.yaml"
        }
      },
      "helm-ls": {
        "yamlls": "yaml-language-server"
      }
    },
    "file_types": {
      "Helm": [
        "**/templates/**/*.tpl",
        "**/templates/**/*.yaml",
        "**/templates/**/*.yml",
        "**/helmfile.d/**/*.yaml",
        "**/helmfile.d/**/*.yml"
      ]
    },
  "vim_mode": false,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "macOS Classic Dark"
}
